# ====================
# NekoCafe .gitignore
# ====================

# --- Docker ---
docker-compose.override.yml
.env

# --- Java (reservation-service) ---
*.class
*.jar
*.war
target/
!.mvn/wrapper/maven-wrapper.jar

# --- Node.js (member-service) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env.local

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Secrets (绝对不能提交) ---
*.pem
*.key
*.p12
secrets.yaml
credentials.json

# --- Misc ---
*.log
*.tmp
temp/
